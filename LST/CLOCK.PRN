 1870 0606                     ld b,6            ;else clear all digits
 1872 210021                   ld hl,seconds     ;starting with seconds
 1875 3600      clr_loop:      ld (hl),0         ;set to 0
 1877 23                       inc hl            ;next digit
 1878 10FB                     djnz clr_loop     ;loop 6 times

 180C 3C                       inc a             ;up one second
 180D 320021                   ld (seconds),a    ;save new seconds
 1810 FE0A                     cp 10             ;check for 10 second count
 1812 20EC                     jr nz,conv_loop   ;jump none to update display
 1814 3E00                     ld a,0            ;else set to 0
 1816 320021                   ld (seconds),a    ;and save it
 1819 3A0121                   ld a,(_10_secs)   ;and up _10_secs

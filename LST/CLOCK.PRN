 1820 FE06                     cp 06             ;check it for full minute
 1822 20DC                     jr nz,conv_loop   ;jump if not to update display
 1824 3E00                     ld a,0            ;else zero _10_secs
 1826 320121                   ld (_10_secs),a   ;and save
 1829 3A0221                   ld a,(minutes)    ;now

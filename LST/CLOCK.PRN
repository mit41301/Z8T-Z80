 182D 320221                   ld (minutes),a    ;and save
 1830 FE0A                     cp 10             ;test for 10 minutes
 1832 20CC                     jr nz,conv_loop   ;jump if not to display new time
 1834 3E00                     ld a,0            ;else zero minutes
 1836 320221                   ld (minutes),a    ;and save
 1839 3A0321                   ld a,(_10_mins)   ;now
 183C 3C                       inc a             ;up _10_mins by one
 183D 320321                   ld (_10_mins),a   ;and save
 1840 FE06                     cp 06             ;test it for 60 mins
 1842 20BC                     jr nz,conv_loop   ;jump if not
 1844 3E00                     ld a,0            ;else zero minutes
 1846 320321                   ld (_10_mins),a   ;and save
 1849 3A0421                   ld a,(hours)      ;now
 184C 3C                       inc a             ;update hours

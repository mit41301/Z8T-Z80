 187D 110521    conv_all:      ld de,_10_hours   ;start from highest digit
 1880 0606                     ld b,6            ;6 digits to do
 1882 1A        con_loop:      ld a,(de)         ;display code; use BC as
 1883 CD8A18                   call con_a        ;pointer to display buffer
 1886 1B                       dec de            ;next lowest digit
 1887 10F9                     djnz con_loop     ;dec B jump not zero
 1889 C9                       ret               ;return from subroutine
                
 188A E5        con_a:         push hl           ;save dis_buff pointer on stack
 188B 21C418                   ld hl,distab      ;HL is used as an index
 188E 85                       add a,l           ;pointer into the display code
 188F 6F                       ld l,a            ;table, add number to convert
 1890 3001                     jr nc,page_ok     ;in A to HL jump if no
 1892 24                       inc h             ;carry else up H into new page
 1893 7E        page_ok:       ld a,(hl)         ;put display code in A
 1894 E1                       pop hl            ;get dis_buff pointer from stack
 1895 77                       ld (hl),a         ;store in display buffer
 1896 23                       inc hl            ;point BC to next display locatio
                n
 1897 C9                       ret               ;all done so return
                
 1898 0EC1      scan_second:   ld c,0c1h         ;load C with outermost time value
 189A C5        sec_loop:      push bc           ;save C on stack
 189B CDAB18                   call scan         ;display three digits
 189E C1                       pop bc            ;get outer timer from stack put i
                n C
 189F 0682                     ld b,coarse       ;set B for coarse delay
 18A1 10FE                     djnz $            ;do coarse delay
 18A3 0D                       dec c             ;now decrement outer delay
 18A4 20F4                     jr nz,sec_loop    ;jump until it reaces zero
 18A6 063E                     ld b,fine         ;now do very quick coarse delay
 18A8 10FE                     djnz $            ;coarse delay loop
 18AA C9                       ret               ;one second done, return
                
 18AB           scan:
 18AB 210621                   ld hl,dis_buff    ;point to 10 hours display code
 18AE 0620                     ld b,20h          ;load B with rotating scan bit

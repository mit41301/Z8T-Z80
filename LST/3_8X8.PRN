 1857 2A0420                   ld hl,(ptr3)        ;
 185A 220A20                   ld (aptr3),hl       ;
 185D 0680                     ld b,80h            ;load B with rotating scan bit
 185F 2A0620    scan_lp2:      ld hl,(aptr1)       ;get first pointer
 1862 7E                       ld a,(hl)           ;put display code into A
 1863 23                       inc hl              ;up pointer
 1864 FEFF                     cp 0ffh             ;is this end code?
 1866 2005                     jr nz,notend1       ;jump away if not else reset
 1868 210E20                   ld hl,dis_buff      ;working pointer to start buff
 186B 7E                       ld a,(hl)           ;get display code
 186C 23                       inc hl              ;up pointer
 186D 220620    notend1:       ld (aptr1),hl       ;save new working pointer
 1870 D381                     out (81h),a         ;output first code to segments
 1872 2A0820                   ld hl,(aptr2)       ;now do all again for 2nd code
 1875 7E                       ld a,(hl)           ;put display code into A
 1876 23                       inc hl              ;next
 1877 FEFF                     cp 0ffh             ;end?
 1879 2005                     jr nz,notend2       ;jump no
 187B 210E20                   ld hl,dis_buff      ;else
 187E 7E                       ld a,(hl)           ;get first display code
 187F 23                       inc hl              ;up poiner to second
 1880 220820    notend2:       ld (aptr2),hl       ;save new pointer
 1883 D382                     out (82h),a         ;output second display byte
 1885 2A0A20                   ld hl,(aptr3)       ;now do all again for 3rd code
 1888 7E                       ld a,(hl)           ;put display code into A
 1889 23                       inc hl              ;next
 188A FEFF                     cp 0ffh             ;end?
 188C 2005                     jr nz,notend3       ;jump no
 188E 210E20                   ld hl,dis_buff      ;else
 1891 7E                       ld a,(hl)           ;get first display code
 1892 23                       inc hl              ;up poiner to second
 1893 220A20    notend3:       ld (aptr3),hl       ;save new pointer
 1896 D383                     out (83h),a         ;output second display byte
 1898 78                       ld a,b              ;get scan bit in A
 1899 D380                     out (80h),a         ;output it to first commons
 189B 0600                     ld b,0              ;load B with display on time
 189D 10FE                     djnz $              ;loop here until delay finished
 189F 47                       ld b,a              ;return scan bit into B
 18A0 AF                       xor a               ;trick to zero A
 18A1 D380                     out (80h),a      ;clear commons to prevent ghosts
 18A3 CB08                     rrc b            ;shift scan bit once to the right
 18A5 D25F18                   jp nc,scan_lp2   ;jump if no into carry flag
 18A8 C1                       pop bc              ;else all 8 scanned
 18A9 109F                     djnz scan_lp1       ;rescan until scan timer = 0
 18AB 2A0020                   ld hl,(ptr1)        ;now up first pointer to
 18AE 23                       inc hl              ;shift display along
 18AF 7E                       ld a,(hl)           ;test for end
 18B0 FEFF                     cp 0ffh             ;of display buffer
 18B2 2003                     jr nz,ptr1_ok       ;jump if not end
 18B4 210E20                   ld hl,dis_buff      ;else point to start
 18B7 220020    ptr1_ok:       ld (ptr1),hl        ;save new pointer



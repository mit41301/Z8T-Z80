Source File Name: 3_8X8.Z8T                                           Page  1


 0000                          ORG 0         ;automatic go
 0000 00                       NOP
 0001 310040                   ld sp,4000h
 0004 C30018                   JP main      ;section
                
 0008           speed          equ 8        ;time delay before shift
                
 1800                          org 1800h
                
 1800 110E20    main:          ld de,dis_buff      ;DE is pointer into dis_buff
 1803 21001B                   ld hl,ASCII_tab     ;HL points to chars to display
 1806 220C20                   ld (code_buff),hl   ;save pointer
 1809 2A0C20    loop:          ld hl,(code_buff)   ;looping here: get pointer
 180C 7E                       ld a,(hl)           ;put character code in A
 180D 23                       inc hl              ;up pointer to next char
 180E 220C20                   ld (code_buff),hl   ;save pointer
 1811 FEFF                     cp 0ffh             ;done all characters?
 1813 281B                     jr z,scaninit       ;jump if ffh as all converted
 1815 6F                       ld l,a              ;put char code into HL
 1816 2600                     ld h,0              ;zero H
 1818 E5                       push hl             ;put char code into BC also
 1819 C1                       pop bc              ;by using the stack
 181A B7                       or a                ;this clears carry flag
 181B ED6A                     adc hl,hl           ;double char code
 181D ED6A                     adc hl,hl           ;double char code again (x4)
 181F ED4A                     adc hl,bc           ;add orginal char code (x5)
 1821 016018                   ld bc,char_tab-(20h*5)  ;load BC with base of char
 1824 ED4A                     adc hl,bc           ;table; add offset
 1826 010500                   ld bc,5             ;now setup to tranfer 5 bytes
 1829 EDB0                     ldir                ;from (HL) to (DE); do tranfer
 182B AF                       xor a               ;clear A
 182C 12                       ld (de),a           ;add space to end of char
 182D 13                       inc de              ;next display buffer location
 182E 18D9                     jr loop             ;do rest of characters
 1830 3EFF      scaninit:      ld a,0ffh           ;mark end of display buffer
 1832 12                       ld (de),a           ;pointer to by DE
 1833 210E20    scan_in2:      ld hl,dis_buff      ;point HL to start of dis_buff
 1836 220020                   ld (ptr1),hl        ;save start
 1839 B7                       or a                ;clear carry
 183A 110800                   ld de,08            ;now get start for second 8x8
 183D ED5A                     adc hl,de           ;8 bytes from first
 183F 220220                   ld (ptr2),hl        ;save second start
 1842 B7                       or a                ;clear carry
 1843 ED5A                     adc hl,de           ;3rd 8 bytes from second
 1845 220420                   ld (ptr3),hl        ;save second start
 1848 0608      scan_dly:      ld b,speed          ;static scan time
 184A C5        scan_lp1:      push bc             ;save scan time
 184B 2A0020                   ld hl,(ptr1)        ;move pointer to
 184E 220620                   ld (aptr1),hl       ;working pointer buffer
 1851 2A0220                   ld hl,(ptr2)        ;second pointer
 1854 220820                   ld (aptr2),hl       ;also


